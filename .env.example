# Server configuration
PORT=5000

# MongoDB Database connections
MONGODB_URI=mongodb://127.0.0.1:27017/pdfpilot
MONGO_URI=mongodb://127.0.0.1:27017/pdfpilot

# Google Gemini API key (Required for AI Chat, Summarize, Explain, and Translate features)
# Get a key from Google AI Studio: https://aistudio.google.com/
GEMINI_API_KEY=your_google_gemini_api_key_here